# Copy this file to .env for local development.
# Never commit your real .env file.

AWS_REGION=us-east-1

# We will fill these in after creating the queues in AWS.
SQS_QUEUE_URL=
SQS_DLQ_URL=

# Worker polling defaults. Long polling can wait up to 20 seconds.
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=10
