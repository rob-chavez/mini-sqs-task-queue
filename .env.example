# Copy this file to .env for local development.
# Never commit your real .env file.

AWS_REGION=us-east-1

SQS_QUEUE_NAME=mini-sqs-task-queue
SQS_DLQ_NAME=mini-sqs-task-queue-dlq

# We will fill these in after creating the queues in AWS.
SQS_QUEUE_URL=
SQS_DLQ_URL=

# Worker polling defaults. Long polling can wait up to 20 seconds.
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=10

# Queue behavior defaults.
SQS_VISIBILITY_TIMEOUT=30
SQS_MAX_RECEIVE_COUNT=3
